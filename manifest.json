{
  "manifest_version": 3,
  "name": "JobLog — Application Tracker",
  "version": "2.1.0",
  "description": "Auto-detects job applications on LinkedIn, Indeed, Naukri, Glassdoor, Hirist and more.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content-scripts/shared.js", "content-scripts/linkedin.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.indeed.com/*", "*://*.indeed.co.in/*"],
      "js": ["content-scripts/shared.js", "content-scripts/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.naukri.com/*"],
      "js": ["content-scripts/shared.js", "content-scripts/naukri.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.glassdoor.com/*", "*://*.glassdoor.co.in/*"],
      "js": ["content-scripts/shared.js", "content-scripts/glassdoor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.hirist.tech/*", "*://*.hirist.com/*"],
      "js": ["content-scripts/shared.js", "content-scripts/hirist.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
